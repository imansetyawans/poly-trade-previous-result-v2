# === Polymarket Auth ===
# Format: private_key:funder_address:signature_type
# Example: 0xabc...:0x123...:0
POLY_WALLETS=

# === Network ===
POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# === Strategy Configuration ===
TRADE_SIZE=1.0
SIGNAL_TRIGGER_SECONDS=3.0
EXECUTION_TRIGGER_SECONDS=1.0
PRICE_GAP_THRESHOLD=50.0
SIM_STARTING_BALANCE=60.0

# === Time of Day Filter (ZoneInfo Strings) ===
USE_SESSION_SHIELD=true
# Timezone list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TRADE_TIMEZONE=Asia/Bangkok
# 24-hour format HH:MM
TRADE_START_TIME=07:00
TRADE_END_TIME=18:00

# === Confirmation Filter ===
USE_CONFIRMATION_FILTER=true

# === Auto-Redeem Engine ===
POSITION_POLL_INTERVAL=60
REDEEM_LOSSES=false
